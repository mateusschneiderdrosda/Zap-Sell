{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/dashboard.html"
    },
    {
      "source": "/leads",
      "destination": "/pages/leads.html"
    },
    {
      "source": "/vendas",
      "destination": "/pages/vendas.html"
    },
    {
      "source": "/agente",
      "destination": "/pages/agente-ia.html"
    },
    {
      "source": "/configuracoes",
      "destination": "/pages/configuracoes.html"
    },
    {
      "source": "/planos",
      "destination": "/pages/planos.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/landing",
      "destination": "/pages/landing.html"
    }
  ],
  "redirects": [
    {
      "source": "/pages/dashboard.html",
      "destination": "/dashboard",
      "permanent": true
    },
    {
      "source": "/pages/leads.html",
      "destination": "/leads",
      "permanent": true
    },
    {
      "source": "/pages/vendas.html",
      "destination": "/vendas",
      "permanent": true
    },
    {
      "source": "/pages/agente-ia.html",
      "destination": "/agente",
      "permanent": true
    },
    {
      "source": "/pages/configuracoes.html",
      "destination": "/configuracoes",
      "permanent": true
    },
    {
      "source": "/pages/planos.html",
      "destination": "/planos",
      "permanent": true
    },
    {
      "source": "/pages/admin.html",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/pages/landing.html",
      "destination": "/landing",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
